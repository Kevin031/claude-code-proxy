{
  "name": "claude-code-proxy",
  "version": "1.0.1",
  "description": "通用 API 代理服务器 - 支持任意路径转发",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:web": "pnpm --filter claude-proxy-web dev",
    "dev:all": "concurrently \"pnpm dev\" \"pnpm dev:web\"",
    "electron": "pnpm build:web && electron .",
    "electron:dev": "concurrently \"pnpm dev\" \"pnpm dev:web\" \"wait-on http://localhost:5173 && electron .\"",
    "build:web": "pnpm --filter claude-proxy-web build",
    "build": "pnpm build:web && electron-builder",
    "dist": "pnpm build",
    "release": "node scripts/release.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:web": "cd web/claude-proxy-web && vitest run --coverage",
    "test:web:watch": "cd web/claude-proxy-web && vitest"
  },
  "keywords": [
    "proxy",
    "api",
    "glm",
    "anthropic",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "electron-is-dev": "^3.0.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "jest": "^30.3.0",
    "nock": "^14.0.12",
    "nodemon": "^3.0.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.claude-proxy.app",
    "productName": "Claude Proxy",
    "publish": null,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "electron/**/*",
      "web/claude-proxy-web/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "icons/icon_512x512.png"
    },
    "icon": "icons/icon.icns"
  },
  "volta": {
    "node": "20.19.0",
    "pnpm": "7.33.7"
  }
}
